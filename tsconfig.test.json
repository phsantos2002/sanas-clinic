{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["vitest/globals", "node"],
    "noEmit": true,
    "isolatedModules": false
  },
  "include": [
    "__tests__/**/*.ts",
    "__tests__/**/*.tsx",
    "vitest.config.ts",
    "vitest.setup.ts",
    "prisma/seed.ts",
    "lib/**/*.ts",
    "services/**/*.ts",
    "types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
