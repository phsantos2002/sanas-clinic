# ══════════════════════════════════════════════════════════════
# LuxCRM — Environment Variables
# Copie este arquivo para .env e preencha os valores
# ══════════════════════════════════════════════════════════════

# ── Supabase (obrigatorio) ────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
# Service role (opcional) — habilita convite de vendedores por email
# (Config > Usuarios). Sem ela, o vendedor se cadastra com o mesmo email
# e o vinculo acontece no primeiro login. NUNCA exponha no client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Database (obrigatorio) ────────────────────────────────────
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxx:password@db.xxx.supabase.co:5432/postgres

# ── App URL ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Vercel CRON (obrigatorio em production) ───────────────────
CRON_SECRET=

# ── Meta / Facebook (obrigatorio para webhook HMAC) ──────────
# Encontre em: Meta for Developers → App → Settings → Basic → App Secret
META_APP_SECRET=

# ── Vercel Blob (auto-configurado pela Vercel) ───────────────
BLOB_READ_WRITE_TOKEN=

# ── WhatsApp nao-oficial — Evolution API / Baileys (recomendado) ──
# Servidor Evolution API v2 self-hosted (Docker/VPS/Railway).
# Com estes 2 valores, o botao "Conectar via QR" da UI usa Baileys.
# EVOLUTION_SERVER_URL=https://sua-evolution.example.com
# EVOLUTION_API_KEY=

# ── WhatsApp — Uazapi (legado, fallback se Evolution ausente) ─
# UAZAPI_SERVER_URL=
# UAZAPI_ADMIN_TOKEN=

# ── Anthropic (opcional) ──────────────────────────────────────
# ANTHROPIC_API_KEY=

# ── Cold Email Resend (opcional — habilita cadências por email) ─
# Obtenha em resend.com. Necessário verificar domínio do remetente.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@seudominio.com.br
# RESEND_FROM_NAME="Equipe Sanas"
# RESEND_WEBHOOK_SECRET=           # Svix secret (painel Resend → Webhooks)

# ══════════════════════════════════════════════════════════════
# NOTA: Chaves configuradas pelo USUARIO na interface Settings:
# OpenAI, Gemini, Replicate, Fal.ai, Meta Pixel, Meta Ads, Google Business
# ══════════════════════════════════════════════════════════════
