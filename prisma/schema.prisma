generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String?
  facebookId      String?          @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  pixels          Pixel[]
  leads           Lead[]
  tags            Tag[]
  stages          Stage[]
  aiConfig        AIConfig?
  whatsappConfig  WhatsAppConfig?
  gaConfig        GAConfig?
}

model AIConfig {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinicName   String   @default("Sanas Clinic")
  systemPrompt String?
  sendAudio    Boolean  @default(false)
  openaiKey    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Pixel {
  id           String   @id @default(cuid())
  pixelId      String
  accessToken  String
  adAccountId  String?
  metaAdsToken String?
  userId       String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lead {
  id           String             @id @default(cuid())
  name         String
  phone        String
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stageId      String?
  stage        Stage?             @relation(fields: [stageId], references: [id])
  tags         LeadTag[]
  stageHistory LeadStageHistory[]
  messages     Message[]
  aiEnabled    Boolean            @default(true)
  source       String?            // "meta", "google", "whatsapp", "manual"
  medium       String?            // "cpc", "organic", "social", "referral"
  campaign     String?            // campaign name
  adName       String?            // ad/adset name
  platform     String?            // "facebook", "instagram", "google", "whatsapp"
  referrer     String?            // original referrer URL
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())
}

model Stage {
  id        String             @id @default(cuid())
  name      String
  order     Int
  eventName String
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads     Lead[]
  history   LeadStageHistory[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([userId, order])
}

model LeadStageHistory {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  stageId   String
  stage     Stage    @relation(fields: [stageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model WhatsAppConfig {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneNumberId String
  accessToken   String
  verifyToken   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model GAConfig {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  measurementId String   // G-XXXXXXXXXX
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads     LeadTag[]
  createdAt DateTime  @default(now())

  @@unique([userId, name])
}

model LeadTag {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([leadId, tagId])
}
